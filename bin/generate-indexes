#!/usr/bin/env bash
# Generate index.md for every directory for browseable listings.
set -euo pipefail

ROOT="${1:-.}"

# Directories to index (PARA + log tree)
find "$ROOT/projects" "$ROOT/areas" "$ROOT/resources" "$ROOT/archive" \
  -type d 2>/dev/null | while read -r dir; do

  index="$dir/index.md"

  # Skip if a hand-written index already exists
  [ -f "$index" ] && continue

  # Relative path from root for the title
  rel="${dir#$ROOT/}"
  title="${rel:-journal}"

  {
    echo "# $title"
    echo ""

    # Parent link
    if [ "$rel" != "." ] && [ -n "$rel" ]; then
      echo "[..](../)"
      echo ""
    fi

    # List subdirectories first
    for entry in "$dir"/*/; do
      [ -d "$entry" ] || continue
      name="$(basename "$entry")"
      [[ "$name" == _* ]] && continue
      echo "- [$name/]($name/)"
    done

    # Then list files (link to .html since pandoc outputs html)
    for entry in "$dir"/*; do
      [ -f "$entry" ] || continue
      name="$(basename "$entry")"
      [[ "$name" == index.md ]] && continue
      [[ "$name" == _* ]] && continue
      [[ "$name" == .* ]] && continue

      # Strip extension for display, link to .html
      display="${name%.md}"
      link="${display}.html"
      echo "- [$display]($link)"
    done
  } > "$index"
done

# Generate root index.md
cat > "$ROOT/index.md" << 'HEREDOC'
# journal

> personal work journal — PARA + Bullet Journal

- [inbox](inbox.html)
- [projects/](projects/)
- [areas/](areas/)
- [resources/](resources/)
- [archive/](archive/)
- [search](search.html)
HEREDOC

echo "Generated index pages"
